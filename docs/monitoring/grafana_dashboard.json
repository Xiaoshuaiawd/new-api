{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "title": "New API 监控总览",
  "uid": "new-api-observability",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "style": "dark",
  "editable": true,
  "refresh": "30s",
  "panels": [
    {
      "type": "table",
      "title": "渠道成功率",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(channel_request_total{status=\"success\"}[$__range])) by (channel) / clamp_min(sum(increase(channel_request_total[$__range])) by (channel), 1)",
          "legendFormat": "{{channel}}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "渠道名称"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "成功率"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Metric": true,
              "__name__": true
            },
            "indexByName": {
              "channel": 0,
              "Value": 1
            },
            "renameByName": {
              "channel": "渠道名称",
              "Value": "成功率"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "showTimeColumn": false,
        "showRowNumbers": false,
        "showColumnFilters": false,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "enablePagination": false,
          "countRows": false
        },
        "search": {
          "enabled": false
        },
        "showColumnPicker": false
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "table",
      "title": "渠道错误明细（15分钟）",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(channel_error_event_total[$__range])",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "enablePagination": false,
          "fields": "",
          "reducer": [
            "lastNotNull"
          ],
          "show": false
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Value"
          }
        ],
        "showColumnFilters": false,
        "showTimeColumn": false,
        "showRowNumbers": false,
        "search": {
          "enabled": false
        },
        "columns": [
          {
            "text": "发生时间",
            "field": "发生时间"
          },
          {
            "text": "渠道名称",
            "field": "渠道名称"
          },
          {
            "text": "渠道ID",
            "field": "渠道ID"
          },
          {
            "text": "模型名称",
            "field": "模型名称"
          },
          {
            "text": "状态码",
            "field": "状态码"
          },
          {
            "text": "错误信息",
            "field": "错误信息"
          },
          {
            "text": "错误类型",
            "field": "错误类型"
          }
        ],
        "showColumnPicker": false
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Metric": true,
              "__name__": true,
              "Value": true
            },
            "renameByName": {
              "channel": "渠道名称",
              "channel_id": "渠道ID",
              "model": "模型名称",
              "status_code": "状态码",
              "detail": "错误信息",
              "error_type": "错误类型",
              "event_time": "发生时间"
            },
            "indexByName": {
              "event_time": 0,
              "channel": 1,
              "channel_id": 2,
              "model": 3,
              "status_code": 4,
              "detail": 5,
              "error_type": 6
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "渠道 RPM（1分钟）",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "channel_rpm",
          "legendFormat": "{{channel}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/min",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "渠道 TPM（1分钟）",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "channel_tpm",
          "legendFormat": "{{channel}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "token",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}